# ============================================================
# YouTube Analytics — environment variables
# Copy this file to `.env` and fill in YOUTUBE_API_KEY.
# ============================================================

# Required: YouTube Data API v3 key.
# Get one from https://console.cloud.google.com/apis/credentials
# (enable the YouTube Data API v3 for the project).
YOUTUBE_API_KEY=your_youtube_api_key_here

# Optional: full SQLAlchemy database URL.
# Default is SQLite at ./data/youtube_analytics.db.
# Examples:
#   DATABASE_URL=sqlite:///data/youtube_analytics.db
#   DATABASE_URL=postgresql://user:pass@localhost:5432/youtube_db

# Optional server bind host. Default 127.0.0.1 (localhost only).
# Use 0.0.0.0 to expose on the LAN or run inside Docker.
# HOST=127.0.0.1

# Optional CORS allowlist (comma-separated).
# Default: http://localhost:8000,http://127.0.0.1:8000
# CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Optional: skip YouTube refetch if a channel was searched within this window.
# Set to 0 to always refetch.
# CHANNEL_REFRESH_SECONDS=86400

# Optional: max videos to fetch per channel.
# TOP_VIDEOS_LIMIT=50

# Logging
DEBUG=False
DB_ECHO=False
LOG_LEVEL=INFO
